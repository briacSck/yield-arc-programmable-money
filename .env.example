# ─────────────────────────────────────────────────────────────
# YIELD Agentic CFO — environment template. Copy to .env and fill.
# NEVER commit .env. No mainnet keys in this repo, ever (invariant #6).
# ─────────────────────────────────────────────────────────────

# --- Arc chain (viem config, see agent/src/chain/arc-chain.ts) ---
# Verified 2026-07-14 (arc-docs): ARC-TESTNET chainId 5042002; USDC is the NATIVE gas token
# (18-dec native accounting vs 6-dec ERC-20 interface at 0x3600…0000 — SAME balance, two views).
# Explorer: https://testnet.arcscan.app
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002          # Arc public testnet (local Hardhat = 31337)
ARC_NATIVE_DECIMALS=18        # real Arc testnet = 18; CI sets 6 explicitly

# --- Circle developer-controlled wallets (testnet only) ---
# Programmatic path is the SDK (@circle-fin/developer-controlled-wallets), used by
# agent/scripts/circle-setup.ts (one-time: entity secret + wallet set + wallets + faucet)
# and by CircleChainExecutor. The `circle` CLI stays for ad-hoc ops.
# Faucet: SDK requestTestnetTokens may be 403 on some key tiers → https://faucet.circle.com
# (20 USDC / address / 2h; has bot-detection, needs a human click).
CIRCLE_API_KEY=
CIRCLE_ACCEPT_TERMS=1         # required for non-interactive circle CLI use (CI/agents)
CIRCLE_ENTITY_SECRET=         # written by circle-setup.ts; recovery file lands OUTSIDE the repo
CIRCLE_WALLET_SET_ID=         # written by circle-setup.ts
CIRCLE_AGENT_WALLET_ID=       # written by circle-setup.ts (the agent's Circle wallet id)
CIRCLE_COMPANY_WALLET_ID=     # written by circle-setup.ts (company treasury wallet id)

# --- Chain executor selection ---
# 'mock' selects MockChainExecutor (dev/tests ONLY, never a default path — invariant #3).
# 'circle' selects CircleChainExecutor (S1 signer model, proven on ARC-TESTNET 2026-07-14):
#   requires CIRCLE_API_KEY, CIRCLE_ENTITY_SECRET, CIRCLE_AGENT_WALLET_ID, AGENT_MANDATE_ADDRESS.
CHAIN_EXECUTOR=

# --- Contracts (filled after deploy) ---
# ERC-8004 registries on Arc testnet (verified 2026-07-14):
#   Identity   0x8004A818BFB912233c491871b3d84c89A494BD9e
#   Reputation 0x8004B663056A597Dffe9eCcC1965A193B7388713
#   Validation 0x8004Cb1BF31DAf7788923b405b754f57acEB4272
# USYC (yield venue candidate): token 0xe9185F0c5F296Ed1797AaE4238D26CCaBEadb86C,
#   Teller 0x9fdF14c5B14173D74C08Af27AebFf39240dC105A (needs support allowlist ticket).
AGENT_MANDATE_ADDRESS=
IDENTITY_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
AGENT_ADDRESS=                # written by circle-setup.ts (agent wallet address)
COMPANY_ADDRESS=              # written by circle-setup.ts (company treasury address)
OWNER_ADDRESS=

# --- Monitoring (§15.4) ---
HEARTBEAT_URL=                # healthchecks.io ping URL

# --- Decision rule knobs (§16.3) — config, not code ---
USER_MIN_USDC=0
MIN_TICKET_USDC=0
HORIZON_DAYS=30
